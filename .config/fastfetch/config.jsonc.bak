{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "padding": {
      "right": 1,
    },
  },
  "display": {
    "separator": "  ",
  },
  "modules": [
    // Title
    {
      "type": "title",
      "format": "{#1}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ {#}{user-name-colored}",
    },
    // System Information
    {
      "type": "custom",
      "format": "{#1}в”Ӯ {#}System Information",
    },
    {
      "type": "os",
      "key": "{#separator}в”Ӯ  {#keys}у°Қ№ OS",
    },
    {
      "type": "kernel",
      "key": "{#separator}в”Ӯ  {#keys}у°’Ӣ Kernel",
    },
    {
      "type": "uptime",
      "key": "{#separator}в”Ӯ  {#keys}у°…җ Uptime",
    },
    {
      "type": "packages",
      "key": "{#separator}в”Ӯ  {#keys}у°Ҹ– Packages",
      "format": "{all}",
    },
    {
      "type": "custom",
      "format": "{#1}в”Ӯ",
    },
    // Desktop Environment
    {
      "type": "custom",
      "format": "{#1}в”Ӯ {#}Desktop Environment",
    },
    {
      "type": "de",
      "key": "{#separator}в”Ӯ  {#keys}у°§Ё DE",
    },
    {
      "type": "custom",
      "key": "{#separator}в”Ӯ  {#keys}уұЎ“ Configuration",
      "format": "Luna-Hyprdots",
    },
    {
      "type": "wm",
      "key": "{#separator}в”Ӯ  {#keys}уұӮ¬ WM",
    },
    {
      "type": "wmtheme",
      "key": "{#separator}в”Ӯ  {#keys}у°үј Theme",
    },
    {
      "type": "display",
      "key": "{#separator}в”Ӯ  {#keys}у°№‘ Resolution",
    },
    // {
    //   "type": "shell",
    //   "key": "{#separator}в”Ӯ  {#keys}у°һ· Shell"
    // },
    // {
    //   "type": "terminalfont",
    //   "key": "{#separator}в”Ӯ  {#keys}у°ӣ– Font"
    // },
    {
      "type": "custom",
      "format": "{#1}в”Ӯ",
    },
    // Hardware Information
    {
      "type": "custom",
      "format": "{#1}в”Ӯ {#}Hardware Information",
    },
    {
      "type": "cpu",
      "key": "{#separator}в”Ӯ  {#keys}у°»  CPU",
    },
    {
      "type": "gpu",
      "key": "{#separator}в”Ӯ  {#keys}у°ў® GPU",
    },
    {
      "type": "memory",
      "key": "{#separator}в”Ӯ  {#keys}у°Қӣ Memory",
    },
    {
      "type": "disk",
      "key": "{#separator}в”Ӯ  {#keys}у°ӢҠ Disk (/)",
      "folders": "/",
    },
    {
      "type": "custom",
      "format": "{#1}в”Ӯ",
    },
    {
      "type": "custom",
      "format": "{#1}в”Ӯ `luna-hyprdots` to update Luna-Hyprdots",
    },
    {
      "type": "custom",
      "format": "{#1}в”Ӯ `wallpapers` to install default wallpapers",
    },
    {
      "type": "custom",
      "format": "{#1}в”Ӯ `quickspeed` to test connection",
    },
    // Colors
    {
      "type": "colors",
      "key": "{#separator}в”Ӯ",
      "symbol": "circle",
    },
    // Footer
    {
      "type": "custom",
      "format": "{#1}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ",
    },
  ],
}
